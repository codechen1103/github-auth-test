# Public URL of this generator web app.
# Local: http://localhost:3000
# Production: https://your-generator.vercel.app
APP_URL=http://localhost:3000

# Create an OAuth App at https://github.com/settings/developers
# Callback URL: ${APP_URL}/api/auth/github/callback
GITHUB_CLIENT_ID=replace_me
GITHUB_CLIENT_SECRET=replace_me

# For public repo generation:
GITHUB_SCOPES=read:user user:email public_repo

# Used to encrypt the HttpOnly session cookie.
# Generate with: openssl rand -base64 32
SESSION_SECRET=replace_with_a_long_random_secret

# Optional: clear GitHub access token after creating a repo.
# true is safer for one-shot generator products.
CLEAR_TOKEN_AFTER_GENERATE=false
